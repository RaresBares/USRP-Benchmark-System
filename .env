# ── Database ──
POSTGRES_USER=usrp
POSTGRES_PASSWORD=usrp_secret
POSTGRES_DB=usrp_bench
DATABASE_URL=postgresql://usrp:usrp_secret@db:5432/usrp_bench

# ── Auth ──
DEFAULT_AUTH_TOKEN=default-bench-token-2024

# ── USRP / Radio ──
CARRIER_FREQUENCY_HZ=2400000000
SAMPLE_RATE_HZ=20000000
BANDWIDTH_HZ=20000000
TX_GAIN_DB=30
RX_GAIN_DB=30
CHANNEL_SNR_DB=20
ANTENNA_TX=TX/RX
ANTENNA_RX=RX2
USRP_DEVICE_ARGS=type=b200

# ── Limits ──
MAX_UPLOAD_MB=200
MAX_SAMPLES=2500000
MAX_WS_CONNECTIONS=100
MAX_PENDING_TASKS=200
TASK_TTL_HOURS=24
