# ── GHCR / Deployment ──
GHCR_OWNER=your-github-username
IMAGE_TAG=latest
ENTRYPOINT_PORT=8000

# ── Database ──
POSTGRES_USER=usrp
POSTGRES_PASSWORD=usrp_secret
POSTGRES_DB=usrp_bench
DATABASE_URL=postgresql://usrp:usrp_secret@db:5432/usrp_bench

# ── Auth ──
DEFAULT_AUTH_TOKEN=default-bench-token-2024

# ── USRP / Radio ──
CARRIER_FREQUENCY_HZ=2400000000
SAMPLE_RATE_HZ=20000000
BANDWIDTH_HZ=20000000
TX_GAIN_DB=30
RX_GAIN_DB=30
CHANNEL_SNR_DB=20
ANTENNA_TX=TX/RX0
ANTENNA_RX=RX1
TX_CHANNEL=0
RX_CHANNEL=0

# ── USRP Mode (false=AWGN simulation, true=real USRP via ZMQ daemons) ──
USE_REAL_USRP=false

# ── ZMQ Daemon Addresses (as seen from worker container) ──
TX_DAEMON_HOST=host.docker.internal
TX_DAEMON_PORT=5557
RX_DAEMON_HOST=host.docker.internal
RX_DAEMON_PORT=5555

# ── USRP Device (used by daemons on host) ──
USRP_TX_ADDR=192.168.10.2
USRP_RX_ADDR=192.168.10.2
MASTER_CLOCK_RATE=250000000

# ── Signal Exchange (shared between worker container and host daemons) ──
SIGNAL_DIR=/data/signals
SIGNAL_DIR_HOST=./data/signals

# ── TX/RX Timing ──
TX_RX_DELAY_DIFF=0.1
INITIAL_DELAY=1.0

# ── Duty Cycle ──
DUTY_CYCLE_MAX_PERCENT=10
DUTY_CYCLE_WINDOW_SEC=60

# ── Listen Before Talk (LBT) ──
LBT_ENABLED=true
LBT_THRESHOLD_DBFS=-50
LBT_SENSE_SAMPLES=200000
LBT_MAX_RETRIES=10
LBT_BACKOFF_SEC=1.0

# ── Limits ──
MAX_UPLOAD_MB=200
MAX_SAMPLES=2500000
MAX_WS_CONNECTIONS=100
MAX_PENDING_TASKS=200
TASK_TTL_HOURS=24
